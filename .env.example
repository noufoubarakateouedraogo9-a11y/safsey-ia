# ════════════════════════════════════════════════════════════════════
#  SAFSEY IA — Variables d'environnement
#  Copier : cp .env.example .env  puis remplir les valeurs
#  Ne JAMAIS committer le fichier .env dans Git.
# ════════════════════════════════════════════════════════════════════

# ── Serveur ──────────────────────────────────────────────────────────
PORT=5000
# En production (Railway/Render), laisser vide → same-domain
CLIENT_ORIGIN=

# ── LLM Texte — Groq (recommandé) ou Ollama local ────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# ── LLM Vision — Analyse image/vidéo ─────────────────────────────────
# Option A : Groq Vision (gratuit si GROQ_API_KEY renseignée)
VISION_PROVIDER=groq
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Option B : OpenRouter (GPT-4o, Gemini, etc.)
# VISION_PROVIDER=openrouter
# VISION_API_KEY=sk-or-v1-...
# VISION_MODEL=openai/gpt-4o
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Image Service — Fooocus / SD WebUI ───────────────────────────────
# Lance avec : python launch.py --api --listen --xformers
SD_WEBUI_URL=http://127.0.0.1:7860
SD_DEFAULT_MODEL=sd_xl_base_1.0.safetensors
SD_STEPS=30
SD_CFG_SCALE=7.5
SD_DENOISING=0.65

# ── Video Service — API Cloud ─────────────────────────────────────────
VIDEO_API_PROVIDER=replicate
REPLICATE_API_TOKEN=
REPLICATE_VIDEO_MODEL=luma/ray-flash-2-540p

# ── Studio Avatar — HeyGen & ElevenLabs ─────────────────────────────
HEYGEN_API_KEY=
ELEVENLABS_API_KEY=

# ── Authentification — Supabase ──────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Paiement — Lemon Squeezy (Merchant of Record) ────────────────────
#
# GRILLE TARIFAIRE (Euros) — synchronisée avec server/billing/pricingConfig.ts
#   Pack Essentiel  19 € = 5 min  de génération vidéo avatar (300 sec-crédits)
#   Pack Créateur   49 € = 15 min de génération vidéo avatar (900 sec-crédits)
#   Pack Business   99 € = 40 min de génération vidéo avatar (2400 sec-crédits)
#
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_WEBHOOK_SECRET=
LEMON_TEST_MODE=false
# Webhook : https://votre-domaine.com/api/webhooks/lemon-squeezy
# Événements à activer : order_created, subscription_created, subscription_updated

# ── Mobile Money ─────────────────────────────────────────────────────
# Ces numéros sont affichés dans la modale de paiement Wave/Orange Money.
# Configurés directement dans src/components/PaymentModal.tsx (WAVE_NUMBER, OM_NUMBER).

# ── Administration ────────────────────────────────────────────────────
ADMIN_PASSWORD=change_this_password_in_production
# Page admin : https://votre-domaine.com/admin-safsey

# ── Frontend ─────────────────────────────────────────────────────────
# Laisser vide = proxy Vite (dev) ou same-domain (production)
VITE_API_URL=

# ── Public App URL ────────────────────────────────────────────────────
PUBLIC_APP_URL=https://votre-domaine.com
